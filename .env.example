APP_NAME=Qring Backend
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

DATABASE_URL=sqlite:///./qring.db

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,capacitor://localhost,ionic://localhost,https://useqring.online,https://www.useqring.online
CORS_ALLOW_ORIGIN_REGEX=^(https?|capacitor|ionic)://(localhost|127\.0\.0\.1|useqring\.online|www\.useqring\.online)(:\d+)?$

SOCKET_PATH=/socket.io
DASHBOARD_NAMESPACE=/realtime/dashboard
SIGNALING_NAMESPACE=/realtime/signaling

LIVEKIT_URL=https://livekit.useqring.online
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WEBHOOK_SECRET=
LIVEKIT_ROOM_PREFIX=qring-session-
APPOINTMENT_SHARE_BASE_URL=https://www.useqring.online
QR_TOKEN_SIGNING_KEY=
QR_TOKEN_ENCRYPTION_KEY=
APPOINTMENT_DEFAULT_GEOFENCE_RADIUS_METERS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_MAX_REQUESTS=20

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@useqring.online

PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
FRONTEND_BASE_URL=https://useqring.online
FIREBASE_PROJECT_ID=qring-7ced9
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=

# SMTP (used for invite + email verification delivery)
# Brevo SMTP relay (recommended). Set SMTP_FROM_EMAIL to a sender/domain verified in Brevo.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=a5fe00001@smtp-brevo.com
SMTP_PASSWORD=REPLACE_WITH_BREVO_SMTP_KEY
SMTP_FROM_EMAIL=no-reply@useqring.online
ADMIN_SIGNUP_KEY=
